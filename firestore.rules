rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /leaderboards/{gameId}/scores/{scoreId} {
      allow read: if true;
      allow create, update, delete: if false;
    }

    match /scoreRateLimits/{userId} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
