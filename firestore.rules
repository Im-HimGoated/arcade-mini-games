rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /leaderboards/{gameId}/scores/{scoreId} {
      allow read: if true;
      allow create, update, delete: if false;
    }

    match /scoreRateLimits/{userId} {
      allow read, write: if false;
    }

    match /profiles/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /friendCodes/{code} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow update: if request.auth != null && resource.data.uid == request.auth.uid && request.resource.data.uid == request.auth.uid;
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
